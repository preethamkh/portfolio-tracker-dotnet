@{
ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8">
            <h1>Dashboard</h1>
            <p class="lead">Welcome, <strong>@User.Identity?.Name</strong>!</p>

            <div class="alert alert-info">
                <h5>You are successfully logged in</h5>
                <p>This is your portfolio dashboard. More features coming soon.</p>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <h5>Quick Links</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li><a href="#" class="btn btn-sm btn-primary mb-2">View Portfolios</a></li>
                        <li><a href="#" class="btn btn-sm btn-primary mb-2">Add Securities</a></li>
                        <li><a href="#" class="btn btn-sm btn-primary mb-2">Track Transactions</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5>Account</h5>
                </div>
                <div class="card-body">
                    <p><strong>Logged in as:</strong> @User.Identity?.Name</p>
                    <form asp-action="Logout" asp-controller="Auth" method="post">
                        <button type="submit" class="btn btn-danger w-100">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>