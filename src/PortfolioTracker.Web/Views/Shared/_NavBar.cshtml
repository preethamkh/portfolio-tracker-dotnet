<header class="bg-white border-b border-gray-200 px-8 py-4">
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-semibold text-gray-800">@ViewData["Title"]</h1>
        <div class="flex items-center gap-3">
            <span class="text-sm text-gray-500">@User.Identity?.Name</span>
            <div
                class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-sm font-medium">
                @(User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")
            </div>
        </div>
    </div>
</header>