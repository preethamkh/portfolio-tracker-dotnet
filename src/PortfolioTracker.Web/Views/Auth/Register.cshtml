@model PortfolioTracker.Web.Models.ViewModels.Auth.RegisterViewModel
@{
ViewData["Title"] = "Create Account";
Layout = "_Layout";
}

<div class="card">
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-600 rounded-2xl mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>
        <p class="text-gray-500 mt-1">Start tracking your investments</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
    <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg">
        <div asp-validation-summary="All" class="text-red-700 text-sm"></div>
    </div>
    }

    <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <div>
            <label asp-for="Username" class="form-label">Username</label>
            <input asp-for="Username" class="form-input" placeholder="johndoe" autocomplete="username" />
            <span asp-validation-for="Username" class="text-red-600 text-xs mt-1"></span>
        </div>

        <div>
            <label asp-for="Email" class="form-label">Email address</label>
            <input asp-for="Email" type="email" class="form-input" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Email" class="text-red-600 text-xs mt-1"></span>
        </div>

        <div>
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-input" placeholder="Min. 8 characters"
                autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-red-600 text-xs mt-1"></span>
        </div>

        <div>
            <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="••••••••"
                autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-red-600 text-xs mt-1"></span>
        </div>

        <button type="submit" class="btn-primary w-full py-3 text-base">
            Create Account
        </button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500">
        Already have an account?
        <a asp-controller="Auth" asp-action="Login" class="text-blue-600 hover:text-blue-700 font-medium">
            Sign in
        </a>
    </p>
</div>

@section Scripts {
@await Html.PartialAsync("_ValidationScripts")
}